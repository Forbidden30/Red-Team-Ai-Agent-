# Anthropic API key — used by Claude Code / Codex CLI integration.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional model override.
ANTHROPIC_MODEL=claude-sonnet-4-6

# Default engagement workspace name (created under agent/engagements/).
ENGAGEMENT=demo

# Optional: Docker image tag for the Kali toolbox (see agent/docker/).
KALI_TOOLBOX_IMAGE=rt-ai-agent-kali:latest
