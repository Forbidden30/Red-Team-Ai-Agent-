# === LLM provider selection ===
# Pick one: "anthropic" (default) or "gemini".
LLM_PROVIDER=anthropic

# --- Anthropic ---
# Required when LLM_PROVIDER=anthropic. Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Defaults to claude-sonnet-4-6 if unset.
# Other options: claude-opus-4-7, claude-haiku-4-5-20251001
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Google Gemini ---
# Required when LLM_PROVIDER=gemini. Get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Defaults to gemini-2.0-flash if unset.
# Other options: gemini-2.5-pro, gemini-2.5-flash, gemini-1.5-pro
GEMINI_MODEL=gemini-2.0-flash

# === Access control ===
# Optional: shared-secret to require on /api/chat (set to any string).
# If unset, the API is open to your deployment's origin only.
API_SHARED_SECRET=

# Optional: comma-separated origins allowed to call the API.
# Leave empty to allow same-origin only.
ALLOWED_ORIGINS=
